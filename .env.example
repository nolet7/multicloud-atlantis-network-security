# Atlantis GitHub identity
ATLANTIS_GH_USER=your-atlantis-bot-user
ATLANTIS_GH_TOKEN=ghp_replace_with_token_or_secret_manager_injection
ATLANTIS_GH_WEBHOOK_SECRET=replace_with_long_random_secret
ATLANTIS_REPO_ALLOWLIST=github.com/your-org/multicloud-atlantis-network-security
ATLANTIS_ATLANTIS_URL=https://atlantis.yourdomain.com

# AWS credentials for Atlantis. Prefer OIDC/role-based auth in production.
AWS_ACCESS_KEY_ID=replace
AWS_SECRET_ACCESS_KEY=replace
AWS_DEFAULT_REGION=us-east-1

# Azure service principal credentials for Atlantis.
ARM_CLIENT_ID=replace
ARM_CLIENT_SECRET=replace
ARM_SUBSCRIPTION_ID=replace
ARM_TENANT_ID=replace

# GCP credentials. Prefer Workload Identity Federation in production.
GOOGLE_CREDENTIALS={"type":"service_account","project_id":"replace"}
GOOGLE_PROJECT=replace
GOOGLE_REGION=us-central1
